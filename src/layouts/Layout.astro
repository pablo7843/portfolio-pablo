---
import '../styles/global.css'
import '@fontsource/space-mono';

interface Props {
  title?: string;
}
const { title = 'PCdev' } = Astro.props;
---
<!doctype html>
<html lang="en" class="dark-mode">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<canvas id="particles-bg" aria-hidden="true"></canvas>
		<div id="cursor-dot"  aria-hidden="true"></div>
		<div id="cursor-ring" aria-hidden="true"></div>

		<!-- Scroll progress terminal bar -->
		<aside id="scroll-bar" aria-hidden="true">
			<span id="sp-section">&gt; INICIO_</span>
			<span id="sp-blocks"></span>
			<span id="sp-pct">[00%]</span>
		</aside>

		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: 'Space Mono', monospace;
	}

	#particles-bg {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
	}

	body > :not(#particles-bg):not(#cursor-dot):not(#cursor-ring):not(#scroll-bar) {
		position: relative;
		z-index: 1;
	}

	/* ── Custom cursor ── */
	@media (hover: hover) {
		* { cursor: none !important; }
	}

	#cursor-dot,
	#cursor-ring {
		position: fixed;
		top: 0;
		left: 0;
		pointer-events: none;
		z-index: 999999;
		border-radius: 50%;
		will-change: transform;
	}

	#cursor-dot {
		width: 6px;
		height: 6px;
		background: var(--primary-color, #00ff00);
		box-shadow: 0 0 6px var(--primary-color, #00ff00);
		transition: background 0.4s, box-shadow 0.4s;
	}

	#cursor-ring {
		width: 28px;
		height: 28px;
		border: 1.5px solid var(--primary-color, #00ff00);
		box-shadow: 0 0 8px color-mix(in srgb, var(--primary-color, #00ff00) 35%, transparent);
		transition: border-color 0.4s, box-shadow 0.4s, background 0.4s;
	}

	/* Hide on touch devices */
	@media (hover: none) {
		#cursor-dot, #cursor-ring { display: none; }
	}

	/* ── Scroll progress bar ── */
	#scroll-bar {
		position: fixed;
		bottom: 0;
		left: 0;
		width: 100%;
		z-index: 500;
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 6px 20px;
		font-family: 'Courier New', monospace;
		font-size: 0.7rem;
		color: var(--primary-color, #00ff00);
		background: color-mix(in srgb, var(--bg-dark, #0a0a14) 80%, transparent);
		backdrop-filter: blur(6px);
		border-top: 1px solid color-mix(in srgb, var(--primary-color, #00ff00) 25%, transparent);
		pointer-events: none;
		user-select: none;
		opacity: 0;
		transition: opacity 0.4s ease;
		box-sizing: border-box;
	}

	#scroll-bar.sp-visible { opacity: 1; }

	#sp-section {
		white-space: nowrap;
		min-width: 160px;
		text-shadow: 0 0 5px var(--primary-color, #00ff00);
		letter-spacing: 1px;
	}

	#sp-blocks {
		flex: 1;
		letter-spacing: 2px;
		text-shadow: 0 0 6px var(--primary-color, #00ff00);
		overflow: hidden;
		white-space: nowrap;
	}

	#sp-pct {
		white-space: nowrap;
		font-weight: bold;
		letter-spacing: 1px;
		text-shadow: 0 0 5px var(--primary-color, #00ff00);
	}

	@media (max-width: 768px) {
		#scroll-bar { display: none; }
	}
</style>

<script>
  import AOS from "aos";

  document.addEventListener("DOMContentLoaded", () => {
    AOS.init({
      duration: 1000,
      once: true,
      offset: 120,
    });

    // ── Particle network background ──────────────────────────────────────────
    const canvas = document.getElementById('particles-bg') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;

    const PARTICLE_COUNT = 90;
    const MAX_DIST = 140;
    const MOUSE_RADIUS = 180;
    const SPEED = 0.4;

    // Theme-aware colors
    function getThemeColor(): { r: number; g: number; b: number } {
      const isLight = document.documentElement.classList.contains('light-mode');
      return isLight
        ? { r: 0, g: 102, b: 204 }   // #0066cc
        : { r: 0, g: 255, b: 0 };    // #00ff00
    }

    let mouse = { x: -9999, y: -9999 };

    window.addEventListener('mousemove', (e) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
    });
    window.addEventListener('mouseleave', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });

    interface Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
      size: number;
    }

    let particles: Particle[] = [];

    function makeParticle(): Particle {
      const angle = Math.random() * Math.PI * 2;
      const speed = SPEED * (0.5 + Math.random());
      return {
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        size: 1.5 + Math.random() * 1.5,
      };
    }

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      for (const p of particles) {
        if (p.x > canvas.width)  p.x = Math.random() * canvas.width;
        if (p.y > canvas.height) p.y = Math.random() * canvas.height;
      }
    }
    window.addEventListener('resize', resize);
    resize();

    particles = Array.from({ length: PARTICLE_COUNT }, makeParticle);

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      const { r, g, b } = getThemeColor();
      const isLight = document.documentElement.classList.contains('light-mode');
      const baseDotAlpha = isLight ? 0.35 : 0.55;
      const baseLineAlpha = isLight ? 0.12 : 0.18;

      // Update + draw particles
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;

        // Bounce off edges
        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

        // Mouse repulsion (subtle push away)
        const dx = p.x - mouse.x;
        const dy = p.y - mouse.y;
        const distMouse = Math.sqrt(dx * dx + dy * dy);
        if (distMouse < MOUSE_RADIUS) {
          const force = (MOUSE_RADIUS - distMouse) / MOUSE_RADIUS;
          p.x += (dx / distMouse) * force * 1.5;
          p.y += (dy / distMouse) * force * 1.5;
        }

        // Draw dot
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r},${g},${b},${baseDotAlpha})`;
        ctx.fill();
      }

      // Draw connections between close particles
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const a = particles[i];
          const bP = particles[j];
          const dx = a.x - bP.x;
          const dy = a.y - bP.y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < MAX_DIST) {
            const alpha = baseLineAlpha * (1 - dist / MAX_DIST);
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(bP.x, bP.y);
            ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
            ctx.lineWidth = 0.8;
            ctx.stroke();
          }
        }

        // Extra connection from particle to mouse cursor
        const p = particles[i];
        const mx = p.x - mouse.x;
        const my = p.y - mouse.y;
        const distM = Math.sqrt(mx * mx + my * my);
        if (distM < MOUSE_RADIUS) {
          const alpha = (isLight ? 0.3 : 0.45) * (1 - distM / MOUSE_RADIUS);
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(mouse.x, mouse.y);
          ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
          ctx.lineWidth = 0.8;
          ctx.stroke();
        }
      }

      requestAnimationFrame(draw);
    }

    draw();
  });
</script>

<script>
// ── Custom cursor ────────────────────────────────────────────────────────────
const initCursor = () => {
  const dot  = document.getElementById('cursor-dot')  as HTMLDivElement | null;
  const ring = document.getElementById('cursor-ring') as HTMLDivElement | null;
  if (!dot || !ring) return;

  let mx = -200, my = -200;
  let rx = -200, ry = -200;
  let targetScale = 1;
  let currentScale = 1;
  let rafId = 0;

  window.addEventListener('mousemove', (e: MouseEvent) => {
    mx = e.clientX;
    my = e.clientY;
  });

  window.addEventListener('mouseleave', () => {
    mx = -200; my = -200;
    rx = -200; ry = -200;
  });

  const INTERACTIVES = 'a, button, [role="button"], label, input, select, .flip-btn, .access-btn, .lamp-wrap, .lang-toggle';

  document.addEventListener('mouseover', (e: MouseEvent) => {
    if ((e.target as Element | null)?.closest(INTERACTIVES)) {
      targetScale = 1.65;
      ring.style.background = 'color-mix(in srgb, var(--primary-color, #00ff00) 10%, transparent)';
      ring.style.boxShadow  = '0 0 18px color-mix(in srgb, var(--primary-color, #00ff00) 55%, transparent)';
    }
  });

  document.addEventListener('mouseout', (e: MouseEvent) => {
    if ((e.target as Element | null)?.closest(INTERACTIVES)) {
      targetScale = 1;
      ring.style.background = '';
      ring.style.boxShadow  = '';
    }
  });

  document.addEventListener('mousedown', () => {
    dot.style.transform = dot.style.transform.replace(/scale\([^)]*\)/, '') + ' scale(0.7)';
  });
  document.addEventListener('mouseup', () => {
    dot.style.transform = dot.style.transform.replace(/ scale\([^)]*\)/, '');
  });

  function animate() {
    currentScale += (targetScale - currentScale) * 0.14;

    dot.style.transform  = `translate(${mx - 3}px, ${my - 3}px)`;
    rx += (mx - rx) * 0.12;
    ry += (my - ry) * 0.12;
    ring.style.transform = `translate(${rx - 14}px, ${ry - 14}px) scale(${currentScale})`;

    rafId = requestAnimationFrame(animate);
  }

  cancelAnimationFrame(rafId);
  animate();
};

initCursor();
document.addEventListener('astro:after-swap', initCursor);
</script>

<script>
// ── Section title glitch (h2.glitch-text) ────────────────────────────────────
const initSectionGlitch = () => {
  const CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%<>/?|\\[]{}~^';
  const rc = () => CHARS[Math.floor(Math.random() * CHARS.length)];
  const FRAMES = 24;
  const INTERVAL = 28;
  const COOLDOWN = FRAMES * INTERVAL + 200;

  function glitchH2(h2: HTMLElement) {
    const textNodes = Array.from(h2.childNodes).filter(
      (n): n is Text => n.nodeType === Node.TEXT_NODE
    );
    const originals = textNodes.map(n => n.textContent ?? '');
    const total = originals.reduce((s, t) => s + t.length, 0);
    if (total < 2) return;

    // Inline glow — bypasses Astro scoped CSS
    h2.style.color = 'var(--primary-color, #00ff00)';
    h2.style.textShadow = '0 0 10px var(--primary-color, #00ff00), 2px 0 8px color-mix(in srgb, var(--primary-color, #00ff00) 50%, transparent), -2px 0 8px color-mix(in srgb, var(--primary-color, #00ff00) 30%, transparent)';

    let frame = 0;
    const id = setInterval(() => {
      frame++;
      const locked = Math.floor((frame / FRAMES) * total);
      let charIdx = 0;

      textNodes.forEach((node, ni) => {
        const orig = originals[ni];
        let out = '';
        for (let i = 0; i < orig.length; i++) {
          if (orig[i] === ' ') { out += ' '; charIdx++; continue; }
          out += charIdx < locked ? orig[i] : rc();
          charIdx++;
        }
        node.textContent = out;
      });

      if (frame >= FRAMES) {
        clearInterval(id);
        textNodes.forEach((node, ni) => { node.textContent = originals[ni]; });
        h2.style.color = '';
        h2.style.textShadow = '';
      }
    }, INTERVAL);
  }

  document.querySelectorAll<HTMLElement>('h2.glitch-text').forEach(h2 => {
    let active = false;
    h2.addEventListener('mouseenter', () => {
      if (active) return;
      active = true;
      glitchH2(h2);
      setTimeout(() => { active = false; }, COOLDOWN);
    });
  });
};

initSectionGlitch();
document.addEventListener('astro:after-swap', initSectionGlitch);
</script>

<script>
// ── Scroll progress terminal bar ─────────────────────────────────────────────
const initScrollBar = () => {
  const bar     = document.getElementById('scroll-bar');
  const blocks  = document.getElementById('sp-blocks');
  const pct     = document.getElementById('sp-pct');
  const section = document.getElementById('sp-section');
  if (!bar || !blocks || !pct || !section) return;

  function getCurrentSection(): string {
    const headings = Array.from(
      document.querySelectorAll<HTMLElement>('h1, h2.glitch-text')
    );
    let label = 'INICIO';
    for (const h of headings) {
      const rect = h.getBoundingClientRect();
      if (rect.top <= window.innerHeight * 0.55) {
        label = (h.textContent ?? '')
          .trim()
          .replace(/\s+/g, '_')
          .toUpperCase()
          .slice(0, 18);
      }
    }
    return label;
  }

  function getBlockCount(): number {
    // Fill available width with block chars (~8px each at 0.7rem monospace)
    const availW = (blocks.parentElement?.clientWidth ?? 600)
      - (section.offsetWidth ?? 160)
      - (pct.offsetWidth ?? 60)
      - 60; // gaps + padding
    return Math.max(8, Math.floor(availW / 9));
  }

  function update() {
    const scrolled = window.scrollY;
    const total    = document.documentElement.scrollHeight - window.innerHeight;
    const ratio    = total > 0 ? Math.min(scrolled / total, 1) : 0;
    const N        = getBlockCount();
    const filled   = Math.round(ratio * N);
    const pctNum   = Math.round(ratio * 100);

    blocks.textContent   = '█'.repeat(filled) + '░'.repeat(N - filled);
    pct.textContent      = `[${String(pctNum).padStart(2, '0')}%]`;
    section.textContent  = `> ${getCurrentSection()}_`;

    bar.classList.toggle('sp-visible', scrolled > 60);
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
};

initScrollBar();
document.addEventListener('astro:after-swap', initScrollBar);
</script>
