---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const githubLink = "https://github.com/pablo7843";
const linkedinLink = "https://www.linkedin.com/in/pabloclimentsanfelix";
const emailLink = "mailto:pclimentsanfelix@gmail.com";

// Si tienes un CV diferente para cada idioma, puedes hacer esto:
const cvLink = lang === 'es' ? "/CV_PabloCliment_ES.pdf" : "/CV_PabloCliment_EN.pdf";
---

<section class="social-wrapper">
  <div class="social-card">
    <h2>{t('social.title')}</h2>

    <p class="bio">
      {t('social.bio')}
    </p>

    <div class="social-links">
      <a href={githubLink} target="_blank" aria-label="GitHub">
        <img class="github" 
            src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg" 
            alt="GitHub" />
      </a>

      <a href={linkedinLink} target="_blank" aria-label="LinkedIn">
        <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/linkedin/linkedin-original.svg" alt="LinkedIn" />
      </a>

      <a href={emailLink} target="_blank" aria-label="Email">
        <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg" alt="Email" />
      </a>
    </div>

    <a href={cvLink} download class="download-cv">{t('social.downloadCV')}</a>
  </div>
</section>

<style>
/* --- ESTILOS MANTENIDOS --- */
.social-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 2rem 1rem; 
}

.social-card {
  width: 100%;
  max-width: 1200px;
  background-color: var(--bg-dark-light);
  padding: 2rem;
  border-radius: 12px;
  text-align: center;
  color: var(--text-primary);
  box-shadow: 0 0 15px var(--primary-color);
  transition: transform 0.3s ease, background-color 0.3s ease;
}

html.light-mode .social-card {
  background-color: var(--bg-light-card);
}

.social-card:hover {
  transform: translateY(-5px);
}

.social-card h2 {
  font-size: 2rem;
  margin-bottom: 1rem;
}

.bio {
  max-width: 800px;
  margin: 0 auto 2rem auto;
  color: var(--text-secondary);
  line-height: 1.6;
}

.social-links {
  display: flex;
  gap: 1.5rem;
  justify-content: center;
  margin-bottom: 2rem;
}

.social-links a img {
  width: 42px;
  height: 42px;
  transition: transform 0.3s ease, filter 0.3s ease;
}

.social-links a:hover img {
  transform: scale(1.2);
}

.social-links a:hover img:not(.github) {
  filter: brightness(1.5);
}

/* --- TU FIX DE GITHUB --- */
html.dark-mode .github {
  filter: invert(1);
}

html.dark-mode .social-links a:hover .github {
  filter: invert(1) brightness(1.5); 
}

html.light-mode .github {
  filter: none; 
}

html.light-mode .social-links a:hover .github {
  filter: brightness(1.5);
}

/* --- BOTÓN CV --- */
.download-cv {
  display: inline-block;
  padding: 0.8rem 1.6rem;
  border: 2px solid var(--primary-color);
  border-radius: 6px;
  color: var(--primary-color);
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s ease;
}

.download-cv:hover {
  background-color: var(--primary-color);
  color: var(--bg-dark);
  transform: translateY(-2px);
}

html.light-mode .download-cv:hover {
  color: var(--bg-light-card);
}

@media (max-width: 640px) {
  .social-card { padding: 1.5rem; }
  .social-links { gap: 1rem; }
}
</style>