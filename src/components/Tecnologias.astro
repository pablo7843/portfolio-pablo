---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const rawTitle = t('tech.section.title');
const cleanTitle = rawTitle.replace(/\s+/g, '');
const titleParts = cleanTitle.split('_');

const D = 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons';

const levelLabels = lang === 'es'
  ? ['Básico', 'Intermedio', 'Avanzado', 'Experto']
  : ['Basic', 'Intermediate', 'Advanced', 'Expert'];

interface Tech {
  name: string;
  icon: string | null;
  level: number;
  desc: string;
}

interface Category {
  title: string;
  accent: string;
  headerIcon: string;
  techs: Tech[];
}

const categories: Category[] = [
  {
    title: t('tech.cat.frontend'),
    accent: '#61DAFB',
    headerIcon: `${D}/react/react-original.svg`,
    techs: [
      { name: "React / Angular", icon: `${D}/react/react-original.svg`,   level: 3, desc: t('tech.desc.react')  },
      { name: "Kotlin",          icon: `${D}/kotlin/kotlin-original.svg`,  level: 3, desc: t('tech.desc.kotlin') },
      { name: "HTML5 & CSS3",    icon: `${D}/html5/html5-original.svg`,    level: 4, desc: t('tech.desc.html')   },
    ]
  },
  {
    title: t('tech.cat.backend'),
    accent: '#8B5CF6',
    headerIcon: `${D}/python/python-original.svg`,
    techs: [
      { name: "Java / Spring",  icon: `${D}/java/java-original.svg`,      level: 3, desc: t('tech.desc.java')   },
      { name: "Python",         icon: `${D}/python/python-original.svg`,   level: 3, desc: t('tech.desc.python') },
      { name: "NodeJS / PHP",   icon: `${D}/nodejs/nodejs-original.svg`,   level: 2, desc: t('tech.desc.node')   },
    ]
  },
  {
    title: t('tech.cat.infra'),
    accent: '#F97316',
    headerIcon: `${D}/docker/docker-original.svg`,
    techs: [
      { name: "Docker",       icon: `${D}/docker/docker-original.svg`,                                          level: 3, desc: t('tech.desc.docker') },
      { name: "Linux OS",     icon: `${D}/linux/linux-original.svg`,                                            level: 4, desc: t('tech.desc.linux')  },
      { name: "AWS / Azure",  icon: `${D}/amazonwebservices/amazonwebservices-original-wordmark.svg`,            level: 2, desc: t('tech.desc.cloud')  },
    ]
  },
  {
    title: t('tech.cat.audit'),
    accent: '#EF4444',
    headerIcon: `${D}/bash/bash-original.svg`,
    techs: [
      { name: "Burp Suite / Metasploit", icon: null, level: 3, desc: t('tech.desc.burp')      },
      { name: "Wireshark / Nmap",        icon: null, level: 3, desc: t('tech.desc.wireshark') },
      { name: "OWASP Top 10",            icon: null, level: 3, desc: t('tech.desc.owasp')     },
    ]
  },
];

const learningTechs = [
  { name: "Flutter", icon: `${D}/flutter/flutter-original.svg` },
  { name: "Dart",    icon: `${D}/dart/dart-original.svg`       },
  { name: "Vue.js",  icon: `${D}/vuejs/vuejs-original.svg`     },
  { name: "Rust",    icon: `${D}/rust/rust-original.svg`       },
];
---

<section id="tech-section">
  <div class="section-header">
    <h2 class="glitch-text">{
      titleParts.map((part, index) => (
        <>{part}{index < titleParts.length - 1 && <span>_</span>}<wbr /></>
      ))
    }</h2>
    <div class="scan-line"></div>
  </div>

  <div class="tech-grid">
    {categories.map((cat) => (
      <div class="tech-card" style={`--accent: ${cat.accent}`} data-aos="fade-up">
        <div class="card-content">

          <div class="card-header">
            <img src={cat.headerIcon} alt={cat.title} class="header-icon" />
            <h3>{cat.title}</h3>
          </div>

          <ul class="tech-list">
            {cat.techs.map(tech => (
              <li class="tech-item">
                <div class="tech-icon-wrap">
                  {tech.icon
                    ? <img src={tech.icon} alt={tech.name} class="tech-icon" />
                    : <span class="tech-icon-fallback">▶</span>
                  }
                </div>
                <div class="tech-info">
                  <div class="tech-top">
                    <span class="tech-name">{tech.name}</span>
                    <div class="level-wrap">
                      {[1, 2, 3, 4].map(i => (
                        <span class={`level-dot ${i <= tech.level ? 'filled' : ''}`}></span>
                      ))}
                      <span class="level-label">{levelLabels[tech.level - 1]}</span>
                    </div>
                  </div>
                  <span class="tech-desc">{tech.desc}</span>
                </div>
              </li>
            ))}
          </ul>

        </div>
      </div>
    ))}
  </div>

  <div class="learning-section" data-aos="fade-up">
    <div class="learning-header">
      <span class="pulse-dot"></span>
      <h3>{t('tech.learning.title')}</h3>
    </div>
    <div class="learning-items">
      {learningTechs.map(tech => (
        <div class="learning-item">
          <img src={tech.icon} alt={tech.name} class="learning-icon" />
          <span>{tech.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #tech-section {
    padding: 80px 20px;
    max-width: 1200px;
    margin: 0 auto;
    font-family: 'Courier New', monospace;
  }

  /* ── Header ── */
  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .glitch-text {
    font-size: 2.5rem;
    font-weight: bold;
    letter-spacing: 4px;
    color: var(--primary-color);
    text-shadow: 0 0 10px var(--primary-color);
    display: block;
    max-width: 100%;
    word-wrap: break-word;
    overflow-wrap: break-word;
    line-height: 1.1;
    margin: 0;
  }

  .glitch-text span {
    display: inline-block;
    color: var(--primary-color);
  }

  .scan-line {
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--primary-color), transparent);
    margin-top: 15px;
    animation: scanMove 3s infinite linear;
  }

  @keyframes scanMove {
    0%   { transform: scaleX(0); opacity: 0; }
    50%  { transform: scaleX(1); opacity: 1; }
    100% { transform: scaleX(0); opacity: 0; }
  }

  /* ── Grid ── */
  .tech-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 40px;
  }

  /* ── Card ── */
  .tech-card {
    background: var(--bg-dark-light, rgba(12,12,26,0.9));
    border: 1px solid rgba(128,130,140,0.2);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .tech-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent);
    box-shadow: 0 12px 40px rgba(0,0,0,0.4), 0 0 20px color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .card-content {
    padding: 28px;
  }

  /* ── Card header ── */
  .card-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(128,130,140,0.2);
  }

  .header-icon {
    width: 36px;
    height: 36px;
    object-fit: contain;
    background: rgba(255,255,255,0.07);
    border-radius: 6px;
    padding: 4px;
    flex-shrink: 0;
  }

  html.light-mode .header-icon {
    background: rgba(0,0,0,0.06);
  }

  .card-header h3 {
    font-size: 1rem;
    font-weight: bold;
    color: var(--accent);
    margin: 0;
    letter-spacing: 1px;
  }

  /* ── Tech list ── */
  .tech-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .tech-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .tech-icon-wrap {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }

  .tech-icon {
    width: 28px;
    height: 28px;
    object-fit: contain;
    background: rgba(255,255,255,0.07);
    border-radius: 5px;
    padding: 3px;
  }

  html.light-mode .tech-icon {
    background: rgba(0,0,0,0.06);
  }

  /* Linux + AWS icons are dark — boost brightness in dark mode */
  html:not(.light-mode) .tech-icon[src*="linux"],
  html:not(.light-mode) .tech-icon[src*="amazonwebservices"] {
    filter: brightness(1.8) saturate(1.2);
  }

  .tech-icon-fallback {
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: bold;
  }

  .tech-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .tech-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tech-name {
    font-size: 0.95rem;
    font-weight: bold;
    color: #fff;
  }

  html.light-mode .tech-name {
    color: #111;
  }

  .tech-desc {
    font-size: 0.78rem;
    color: var(--text-secondary, #888);
    opacity: 0.75;
  }

  /* ── Level indicator ── */
  .level-wrap {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .level-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid var(--accent);
    background: transparent;
    transition: background 0.2s;
  }

  .level-dot.filled {
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent);
  }

  .level-label {
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.5px;
    margin-left: 4px;
    opacity: 0.85;
  }

  /* ── Learning section ── */
  .learning-section {
    background: var(--bg-dark-light);
    border: 1px solid rgba(128,130,140,0.2);
    border-left: 3px solid var(--primary-color);
    border-radius: 6px;
    padding: 28px 32px;
  }

  .learning-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .learning-header h3 {
    font-size: 0.95rem;
    color: var(--primary-color);
    margin: 0;
    letter-spacing: 1px;
  }

  .pulse-dot {
    width: 10px;
    height: 10px;
    background: var(--primary-color);
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 var(--primary-color); opacity: 1; }
    100% { box-shadow: 0 0 0 10px transparent; opacity: 0.6; }
  }

  .learning-items {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .learning-item {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(128,130,140,0.2);
    border-radius: 6px;
    padding: 10px 16px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .learning-item:hover {
    border-color: var(--primary-color);
    transform: translateY(-2px);
  }

  html.light-mode .learning-item {
    background: rgba(0,0,0,0.04);
  }

  .learning-icon {
    width: 24px;
    height: 24px;
    object-fit: contain;
  }

  .learning-item span {
    font-size: 0.9rem;
    font-weight: bold;
    color: #fff;
    letter-spacing: 0.5px;
  }

  html.light-mode .learning-item span {
    color: #222;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .tech-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .glitch-text { font-size: 2rem; letter-spacing: 2px; }
    .card-content { padding: 20px; }
    .learning-section { padding: 20px; }
  }
</style>
