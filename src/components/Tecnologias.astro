---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// --- LÓGICA DE TÍTULO SIN ESPACIOS ---
const rawTitle = t('tech.section.title');
// Eliminamos cualquier espacio accidental y dividimos por el guion bajo
const cleanTitle = rawTitle.replace(/\s+/g, ''); 
const titleParts = cleanTitle.split('_');

const categories = [
  {
    title: t('tech.cat.frontend'),
    icon: "💻",
    techs: [
      { name: "React / Angular", desc: t('tech.desc.react') },
      { name: "Kotlin", desc: t('tech.desc.kotlin') },
      { name: "HTML5 & CSS3", desc: t('tech.desc.html') }
    ]
  },
  {
    title: t('tech.cat.backend'),
    icon: "⚙️",
    techs: [
      { name: "Java / Spring Security", desc: t('tech.desc.java') },
      { name: "Python", desc: t('tech.desc.python') },
      { name: "NodeJS / PHP", desc: t('tech.desc.node') }
    ]
  },
  {
    title: t('tech.cat.infra'),
    icon: "🛡️",
    techs: [
      { name: "Docker", desc: t('tech.desc.docker') },
      { name: "Linux OS", desc: t('tech.desc.linux') },
      { name: "Cloud (AWS/Azure)", desc: t('tech.desc.cloud') }
    ]
  },
  {
    title: t('tech.cat.audit'),
    icon: "🚨",
    techs: [
      { name: "Burp Suite / Metasploit", desc: t('tech.desc.burp') },
      { name: "Wireshark / Nmap", desc: t('tech.desc.wireshark') },
      { name: "OWASP", desc: t('tech.desc.owasp') }
    ]
  }
];

const learningTechs = ["Python", "Flutter", "Dart", "Vue.js", "Rust"];
---

<section id="tech-section">
  <div class="section-header">
    <h2 class="glitch-text">{
      titleParts.map((part, index) => (
        <>{part}{index < titleParts.length - 1 && <span>_</span>}<wbr /></>
      ))
    }</h2>
    <div class="scan-line"></div>
  </div>

  <div class="tech-grid">
    {categories.map((cat) => (
      <div class="tech-card" data-aos="fade-up">
        <div class="card-radar"></div>
        <div class="card-content">
          <div class="card-header">
            <span class="icon">{cat.icon}</span>
            <h3>{cat.title}</h3>
          </div>
          <ul class="tech-list">
            {cat.techs.map(tech => (
              <li>
                <div class="tech-info">
                  <div class="tech-name-wrapper">
                    <span class="status-dot"></span>
                    <span class="tech-name">{tech.name}</span>
                  </div>
                  <span class="tech-desc">{tech.desc}</span>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="card-footer">
          <span class="scanning-text">{t('tech.data.type')}</span>
          <span class="status-ok">{t('tech.status.secure')}</span>
        </div>
      </div>
    ))}
  </div>

  <div class="learning-section" data-aos="fade-up">
    <div class="learning-header">
      <div class="loader-container">
        <div class="loader-bar"></div>
      </div>
      <h3><span class="pulse-icon"></span> {t('tech.learning.title')}</h3>
    </div>
    <div class="learning-content">
      <div class="tech-ticker">
        {learningTechs.map((tech) => (
          <div class="learning-item">
            <span class="code-bracket">[</span>
            <span class="tech-name-learning">{tech}</span>
            <span class="code-bracket">]</span>
          </div>
        ))}
      </div>
    </div>
    <div class="learning-footer">
      <span class="scanning-text">{t('tech.learning.buffering')}</span>
      <span>{t('tech.learning.source')}</span>
    </div>
  </div>
</section>

<style>
  #tech-section {
    padding: 80px 20px;
    max-width: 1200px;
    margin: 0 auto;
    font-family: 'Courier New', monospace;
  }

  .section-header { 
    text-align: center; 
    margin-bottom: 60px; 
  }
  
  /* --- ESTILO DE TÍTULO TIPO TERMINAL --- */
  .glitch-text { 
    font-size: 2.5rem; 
    font-weight: bold; 
    letter-spacing: 4px; 
    color: var(--primary-color);
    text-shadow: 0 0 10px var(--primary-color);
    display: block; /* Ocupa el ancho para permitir el salto */
    max-width: 100%;
    word-wrap: break-word;
    overflow-wrap: break-word;
    line-height: 1.1;
    margin: 0;
  }

  .glitch-text span {
    display: inline-block;
    color: var(--primary-color);
  }

  .scan-line { 
    width: 100%; 
    height: 2px; 
    background: linear-gradient(90deg, transparent, var(--primary-color), transparent); 
    margin-top: 15px; 
    animation: scanMove 3s infinite linear; 
  }

  @keyframes scanMove { 
    0% { transform: scaleX(0); opacity: 0; } 
    50% { transform: scaleX(1); opacity: 1; } 
    100% { transform: scaleX(0); opacity: 0; } 
  }

  /* ----- GRID PRINCIPAL ----- */
  .tech-grid { 
    display: grid; 
    grid-template-columns: 1fr 1fr; 
    gap: 30px; 
    margin-bottom: 40px; 
  }

  .tech-card {
    background: var(--bg-dark-light, rgba(12, 12, 26, 0.9));
    border: 1px solid rgba(128, 130, 140, 0.2); 
    padding: 30px;
    position: relative;
    overflow: hidden;
  }

  .tech-card:hover { 
    border-color: var(--primary-color);
    box-shadow: 0 0 20px rgba(0, 255, 0, 0.15); 
  }

  .card-radar {
    position: absolute;
    top: -50%; left: -50%;
    width: 200%; height: 200%;
    background: conic-gradient(from 0deg, rgba(255,255,255,0.08) 0deg, transparent 60deg);
    animation: radarRotate 6s infinite linear;
    pointer-events: none;
  }

  @keyframes radarRotate { to { transform: rotate(360deg); } }

  .card-header {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 25px;
    border-bottom: 1px solid rgba(128, 130, 140, 0.2);
    padding-bottom: 15px;
  }

  .card-header h3 { font-size: 1.2rem; color: #fff; margin: 0; }
  .tech-list { list-style: none; padding: 0; }
  .tech-list li { margin: 18px 0; }
  .tech-info { display: flex; flex-direction: column; gap: 4px; }
  
  .tech-name-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tech-name { font-size: 1.1rem; font-weight: bold; color: #fff; }
  .tech-desc { font-size: 0.85rem; color: var(--text-secondary, #a0a0a0); opacity: 0.7; padding-left: 18px; }

  .status-dot { 
    width: 8px; height: 8px; 
    background: var(--primary-color); 
    border-radius: 50%; 
    box-shadow: 0 0 8px var(--primary-color); 
  }

  .card-footer {
    margin-top: 25px;
    font-size: 0.7rem;
    display: flex;
    justify-content: space-between;
    border-top: 1px dotted rgba(128, 130, 140, 0.3);
    padding-top: 15px;
    color: var(--text-secondary);
  }

  .scanning-text { color: #00d4ff; opacity: 0.8; }
  .status-ok { color: var(--primary-color); font-weight: bold; animation: blink 1.5s infinite; }
  @keyframes blink { 50% { opacity: 0.3; } }

  /* ----- SECCIÓN HORIZONTAL ----- */
  .learning-section {
    background: var(--bg-dark-light);
    border: 1px solid rgba(128, 130, 140, 0.2);
    padding: 30px;
    position: relative;
    border-radius: 4px;
  }

  .learning-header h3 {
    font-size: 1.1rem;
    color: #fff;
    margin: 15px 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .pulse-icon {
    width: 10px; height: 10px;
    background: var(--primary-color);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 var(--primary-color); opacity: 1; }
    100% { box-shadow: 0 0 0 10px transparent; opacity: 0; }
  }

  .loader-container { width: 100%; height: 4px; background: rgba(128, 130, 140, 0.2); position: relative; overflow: hidden; }
  .loader-bar { width: 100%; height: 100%; background: var(--primary-color); animation: loading-fixed 10s infinite; }

  .tech-ticker { display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; padding: 20px 0; }
  .learning-item { font-size: 1.2rem; font-weight: bold; color: #fff; }
  .code-bracket { color: #00d4ff; }

  .learning-footer {
    margin-top: 20px; font-size: 0.7rem; display: flex;
    justify-content: space-between; color: var(--text-secondary);
    border-top: 1px solid rgba(128, 130, 140, 0.2); padding-top: 10px;
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 900px) {
    .tech-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .glitch-text { 
      font-size: 2.2rem; 
      letter-spacing: 2px; 
    }
  }
</style>