---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const rawTitle = t('projects.section.title');
const cleanTitle = rawTitle.replace(/\s+/g, '');
const titleParts = cleanTitle.split('_');

const D = 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons';

const techData: Record<string, { icon: string; color: string }> = {
  'kotlin':   { icon: `${D}/kotlin/kotlin-original.svg`,     color: '#7F52FF' },
  'android':  { icon: `${D}/android/android-original.svg`,   color: '#3DDC84' },
  'flutter':  { icon: `${D}/flutter/flutter-original.svg`,   color: '#02569B' },
  'supabase': { icon: `${D}/supabase/supabase-original.svg`,  color: '#3ECF8E' },
  'nodejs':   { icon: `${D}/nodejs/nodejs-original.svg`,     color: '#339933' },
  'docker':   { icon: `${D}/docker/docker-original.svg`,     color: '#2496ED' },
  'python':   { icon: `${D}/python/python-original.svg`,     color: '#3776AB' },
  'react':    { icon: `${D}/react/react-original.svg`,       color: '#61DAFB' },
  'fastapi':  { icon: `${D}/fastapi/fastapi-original.svg`,   color: '#009688' },
};

const getTech = (name: string) =>
  techData[name.toLowerCase().replace(/\s+/g, '')] ?? { icon: '', color: '#888' };

const censor = (s: string) => s.split('').map(c => /\s/.test(c) ? c : '█').join('');

const cls  = lang === 'es' ? 'CLASIFICADO'    : 'CLASSIFIED';
const dcls = lang === 'es' ? 'DESCLASIFICADO' : 'DECLASSIFIED';
const req  = lang === 'es' ? 'SOLICITAR_ACCESO' : 'REQUEST_ACCESS';
const dec  = lang === 'es' ? 'DESCLASIFICANDO...' : 'DECRYPTING...';

interface Trabajo {
  title: string;
  description: string;
  image: string;
  technologies: string[];
  details: string;
  github: string;
  accent: string;
  inDevelopment?: boolean;
}

const trabajos: Trabajo[] = [
  {
    title: 'Star Wars Nexus',
    description: t('projects.starwarsnexus.desc'),
    image: '/starwars-nexus.svg',
    technologies: ['Kotlin', 'Android'],
    details: t('projects.starwarsnexus.details'),
    github: 'https://github.com/pablo7843/StarWarsNexus',
    accent: '#7F52FF',
  },
  {
    title: 'QR-Shield',
    description: t('projects.qrshield.desc'),
    image: '/qr-shield.svg',
    technologies: ['Flutter', 'Supabase'],
    details: t('projects.qrshield.details'),
    github: 'https://github.com/pablo7843/qr_shield',
    accent: '#3ECF8E',
  },
  {
    title: 'SecDash',
    description: t('projects.secdash.desc'),
    image: '/secdash.svg',
    technologies: ['NodeJS', 'Docker'],
    details: t('projects.secdash.details'),
    github: 'https://github.com/pablo7843/secdash',
    accent: '#2496ED',
  },
  {
    title: 'Code Security Reviewer',
    description: t('projects.codereviewer.desc'),
    image: '/code-reviewer.svg',
    technologies: ['Python', 'React'],
    details: t('projects.codereviewer.details'),
    github: '#',
    accent: '#61DAFB',
    inDevelopment: true,
  },
  {
    title: 'Bot Discord',
    description: t('projects.botdiscord.desc'),
    image: '/bot-discord.svg',
    technologies: ['Python', 'Supabase'],
    details: t('projects.botdiscord.details'),
    github: 'https://github.com/pablo7843/discord-bot',
    accent: '#5865F2',
  },
  {
    title: 'Shrtn.io',
    description: t('projects.shrtnio.desc'),
    image: '/shrtn-io.svg',
    technologies: ['Python', 'FastAPI'],
    details: t('projects.shrtnio.details'),
    github: 'https://github.com/pablo7843/shrtn.io',
    accent: '#009688',
  },
];
---

<div class="trabajos-wrapper-outer">
  <h2 class="glitch-text">{
    titleParts.map((part, index) => (
      <>{part}{index < titleParts.length - 1 && <span>_</span>}<wbr /></>
    ))
  }</h2>

  <div class="trabajos-container">
    {trabajos.map((trabajo, index) => (
      <div class="flip-card" style={`--accent: ${trabajo.accent}`} data-aos="fade-up">
        <div class="flip-card-inner" id={`card-inner-${index}`}>

          <!-- FRONT -->
          <div class="flip-card-front">
            <div class="accent-bar"></div>

            <div class="image-header">
              {trabajo.inDevelopment && (
                <span class="dev-badge">
                  <span class="dev-dot"></span>
                  {lang === 'es' ? 'En desarrollo' : 'In development'}
                </span>
              )}
              <img src={trabajo.image} alt={trabajo.title} class="imagen-trabajo" />
            </div>

            <div class="card-body">
              <h3>{trabajo.title}</h3>
              <p class="descripcion">{trabajo.description}</p>

              <div class="tecnologias">
                {trabajo.technologies.map(tech => {
                  const td = getTech(tech);
                  return (
                    <span class="tech-badge" style={`border-color: ${td.color}; background: ${td.color}18`}>
                      {td.icon && <img src={td.icon} alt={tech} class="tech-icon" />}
                      <span class="tech-name" style={`color: ${td.color}`}>{tech}</span>
                    </span>
                  );
                })}
              </div>

              <button
                class="flip-btn"
                onclick={`document.getElementById('card-inner-${index}').classList.add('is-flipped')`}
              >
                {t('projects.btn.details')} ▶
              </button>
            </div>
          </div>

          <!-- BACK -->
          <div class="flip-card-back">
            <div class="accent-bar"></div>

            <div class="back-header">
              <h3 class="back-title">{trabajo.title}</h3>
              <span class="specs-label">{t('projects.label.specs')}</span>
            </div>

            <div class="scroll-area">
              <!-- Classified stamp -->
              <div class="cls-stamp" id={`stamp-${index}`}>
                <span>⬛ {cls} ⬛</span>
                <span class="access-denied">{lang === 'es' ? 'NIVEL_ACCESO: DENEGADO' : 'ACCESS_LEVEL: DENIED'}</span>
              </div>
              <!-- Declassified stamp (hidden initially) -->
              <div class="dcls-stamp hidden" id={`dcls-stamp-${index}`}>
                <span>✅ {dcls}</span>
              </div>

              <p class="details-text"
                 id={`details-${index}`}
                 data-real={trabajo.details}
                 data-dec={dec}>{censor(trabajo.details)}</p>
            </div>

            <div class="back-actions">
              <!-- Access button (shown when classified) -->
              <button
                class="action-link access-btn"
                id={`access-btn-${index}`}
                data-index={index}
              >🔓 {req}</button>

              <!-- Github link (hidden until declassified) -->
              {trabajo.inDevelopment ? (
                <span class="action-link disabled hidden" id={`github-${index}`}>
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                  {t('projects.label.comingSoon')}
                </span>
              ) : (
                <a href={trabajo.github} target="_blank" rel="noopener" class="action-link github hidden" id={`github-${index}`}>
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                  {t('projects.label.code')}
                </a>
              )}

              <button
                class="back-btn"
                onclick={`document.getElementById('card-inner-${index}').classList.remove('is-flipped')`}
              >◀ {t('projects.btn.back')}</button>
            </div>
          </div>

        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .trabajos-wrapper-outer {
    max-width: 1200px;
    margin: 80px auto;
    padding: 0 20px;
    font-family: 'Courier New', monospace;
  }

  /* ── Title ── */
  .glitch-text {
    font-size: 2.5rem;
    font-weight: bold;
    letter-spacing: 4px;
    color: var(--primary-color);
    text-shadow: 0 0 10px var(--primary-color);
    text-align: center;
    margin-bottom: 40px;
    line-height: 1.1;
    display: block;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .glitch-text span {
    color: var(--primary-color);
    display: inline-block;
  }

  /* ── Grid ── */
  .trabajos-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    perspective: 2000px;
  }

  /* ── Flip card shell ── */
  .flip-card {
    height: 520px;
    width: 100%;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }

  .is-flipped { transform: rotateY(180deg); }

  .flip-card-front,
  .flip-card-back {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 8px;
    border: 1px solid rgba(128, 130, 140, 0.2);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .flip-card:hover .flip-card-front {
    border-color: var(--accent);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 20px color-mix(in srgb, var(--accent) 15%, transparent);
  }

  /* ── Accent bar top ── */
  .accent-bar {
    height: 3px;
    background: var(--accent);
    flex-shrink: 0;
    box-shadow: 0 0 8px var(--accent);
  }

  /* ── Front: image header ── */
  .image-header {
    height: 190px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background: color-mix(in srgb, var(--accent) 8%, var(--bg-dark-light, #0c0c1a));
    border-bottom: 1px solid rgba(128, 130, 140, 0.15);
    overflow: hidden;
  }

  .image-header::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 110%, color-mix(in srgb, var(--accent) 18%, transparent), transparent 65%);
    pointer-events: none;
  }

  .imagen-trabajo {
    width: 85%;
    height: 85%;
    object-fit: contain;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.5));
  }

  /* ── In-development badge ── */
  .dev-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 5px;
    background: rgba(255, 200, 0, 0.12);
    border: 1px solid rgba(255, 200, 0, 0.4);
    color: #ffc800;
    font-size: 0.65rem;
    font-weight: bold;
    padding: 4px 8px;
    border-radius: 4px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .dev-dot {
    width: 6px;
    height: 6px;
    background: #ffc800;
    border-radius: 50%;
    animation: blink 1.2s infinite;
  }

  @keyframes blink { 50% { opacity: 0.2; } }

  /* ── Front: card body ── */
  .card-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    background: var(--bg-dark-light, #0c0c1a);
  }

  .card-body h3 {
    color: #fff;
    font-size: 1.2rem;
    margin: 0 0 0.4rem;
    letter-spacing: 0.5px;
  }

  html.light-mode .card-body h3 { color: #111; }

  .descripcion {
    color: var(--text-secondary, #a0a0a0);
    font-size: 0.85rem;
    margin: 0 0 1rem;
    line-height: 1.5;
  }

  .tecnologias {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: auto;
  }

  .tech-badge {
    padding: 3px 9px;
    border-radius: 4px;
    border: 1px solid;
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.72rem;
    font-weight: bold;
  }

  .tech-icon {
    width: 13px;
    height: 13px;
    object-fit: contain;
  }

  .flip-btn {
    margin-top: 1rem;
    width: 100%;
    padding: 10px;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: bold;
    letter-spacing: 1px;
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    border-radius: 4px;
    transition: background 0.2s, color 0.2s;
  }

  .flip-btn:hover {
    background: var(--accent);
    color: #000;
  }

  /* ── Back face ── */
  .flip-card-back {
    background: var(--bg-dark-light, #0c0c1a);
    transform: rotateY(180deg);
  }

  .flip-card-back .accent-bar {
    flex-shrink: 0;
  }

  .back-header {
    padding: 1.25rem 1.5rem 1rem;
    border-bottom: 1px solid rgba(128, 130, 140, 0.2);
    flex-shrink: 0;
  }

  .back-title {
    color: var(--accent);
    font-size: 1.1rem;
    margin: 0 0 4px;
    letter-spacing: 0.5px;
  }

  .specs-label {
    font-size: 0.65rem;
    color: var(--text-secondary, #888);
    letter-spacing: 1px;
    opacity: 0.7;
  }

  .scroll-area {
    flex-grow: 1;
    overflow-y: auto;
    padding: 1rem 1.5rem;
    scrollbar-width: thin;
    scrollbar-color: var(--accent) transparent;
  }

  .scroll-area::-webkit-scrollbar { width: 3px; }
  .scroll-area::-webkit-scrollbar-track { background: transparent; }
  .scroll-area::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 2px; }

  .details-text {
    font-size: 0.82rem;
    line-height: 1.65;
    color: var(--text-secondary, #ccc);
    margin: 0;
  }

  html.light-mode .details-text { color: #333; }

  /* ── Back: action buttons ── */
  .back-actions {
    padding: 1rem 1.5rem 1.25rem;
    border-top: 1px solid rgba(128, 130, 140, 0.2);
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .action-link {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px 10px;
    font-family: inherit;
    font-size: 0.75rem;
    font-weight: bold;
    border-radius: 4px;
    text-decoration: none;
    border: 1px solid var(--accent);
    color: var(--accent);
    cursor: pointer;
    background: transparent;
    transition: background 0.2s, color 0.2s;
    letter-spacing: 0.5px;
  }

  .action-link.github:hover {
    background: var(--accent);
    color: #000;
  }

  .action-link.disabled {
    border-color: rgba(128,130,140,0.3);
    color: #666;
    cursor: not-allowed;
    opacity: 0.6;
  }

  .back-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px 10px;
    font-family: inherit;
    font-size: 0.75rem;
    font-weight: bold;
    border-radius: 4px;
    border: 1px solid rgba(255, 68, 68, 0.5);
    color: #ff6b6b;
    cursor: pointer;
    background: transparent;
    transition: background 0.2s, color 0.2s;
    letter-spacing: 0.5px;
  }

  .back-btn:hover {
    background: rgba(255,68,68,0.15);
    border-color: #ff4444;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .trabajos-container { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .glitch-text { font-size: 2rem; letter-spacing: 2px; }
    .trabajos-container { grid-template-columns: 1fr; }
    .flip-card { height: 500px; }
  }

  /* ── Classified / Declassified stamps ── */
  .cls-stamp, .dcls-stamp {
    font-size: 0.7rem;
    font-weight: bold;
    letter-spacing: 2px;
    padding: 5px 10px;
    border-radius: 3px;
    margin-bottom: 10px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cls-stamp {
    background: rgba(255, 40, 40, 0.08);
    border: 1px solid rgba(255, 40, 40, 0.5);
    color: #ff4444;
  }

  .dcls-stamp {
    background: rgba(0, 255, 0, 0.07);
    border: 1px solid rgba(0, 255, 0, 0.4);
    color: var(--primary-color);
  }

  html.light-mode .dcls-stamp {
    color: #0066cc;
    border-color: rgba(0, 102, 204, 0.4);
    background: rgba(0, 102, 204, 0.06);
  }

  .access-denied {
    font-size: 0.6rem;
    opacity: 0.7;
    letter-spacing: 1px;
  }

  /* Censored text looks blocky */
  .details-text.censored {
    color: rgba(255, 60, 60, 0.55);
    letter-spacing: 0.5px;
    word-break: break-all;
  }

  html.light-mode .details-text.censored {
    color: rgba(180, 0, 0, 0.4);
  }

  /* Access request button */
  .access-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px 10px;
    font-family: inherit;
    font-size: 0.75rem;
    font-weight: bold;
    border-radius: 4px;
    border: 1px solid rgba(255, 40, 40, 0.5);
    color: #ff6060;
    cursor: pointer;
    background: transparent;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    letter-spacing: 0.5px;
  }

  .access-btn:hover:not(:disabled) {
    background: rgba(255, 40, 40, 0.12);
    border-color: #ff4444;
  }

  .access-btn:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .hidden { display: none !important; }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.access-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx   = btn.dataset.index!;
      const p     = document.getElementById(`details-${idx}`) as HTMLElement;
      const stamp = document.getElementById(`stamp-${idx}`);
      const dStamp= document.getElementById(`dcls-stamp-${idx}`);
      const gh    = document.getElementById(`github-${idx}`);
      const dec   = p.dataset.dec ?? 'DECRYPTING...';

      if (!p || p.dataset.done === '1') return;

      const real    = p.dataset.real!;
      const current = real.split('').map(c => /\s/.test(c) ? c : '█');

      btn.textContent = `⏳ ${dec}`;
      btn.disabled    = true;
      p.classList.add('censored');

      let i = 0;
      function step() {
        // Reveal 5 chars per tick — ~2s for 500 chars
        for (let k = 0; k < 5 && i < current.length; k++, i++) {
          current[i] = real[i]!;
        }
        p.textContent = current.join('');

        if (i < current.length) {
          setTimeout(step, 20);
        } else {
          p.textContent = real;
          p.dataset.done = '1';
          p.classList.remove('censored');
          btn.classList.add('hidden');
          stamp?.classList.add('hidden');
          dStamp?.classList.remove('hidden');
          gh?.classList.remove('hidden');
        }
      }
      step();
    });
  });
</script>
