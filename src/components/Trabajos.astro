---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// --- LÓGICA DE TÍTULO SIN ESPACIOS ---
const rawTitle = t('projects.section.title'); 
const cleanTitle = rawTitle.replace(/\s+/g, ''); 
const titleParts = cleanTitle.split('_');

const trabajos = [
    {
        title: 'Star WikiWars',
        description: t('projects.starwars.desc'),
        image: '/Star-Wars-photo.png',
        technologies: ['Kotlin'],
        details: t('projects.starwars.details'),
        github: 'https://github.com/pablo7843/StarWarsApp'
    },
    {
        title: 'Qr-Shield',
        description: t('projects.qrshield.desc'),
        image: '/qr-shield.png',
        technologies: ['Flutter', 'Supabase'],
        details: t('projects.qrshield.details'),
        github: 'https://github.com/pablo7843/qr_shield'
    },
    {
        title: 'Music web reproducer',
        description: t('projects.music.desc'),
        image: '/harmoniq.png',
        technologies: ['React', 'Supabase'],
        details: t('projects.music.details'),
        github: 'https://github.com/pablo7843/HarmoniQ'
    }
];

const getTechIcon = (tech: string) => {
    const name = tech.toLowerCase().replace(/\s+/g, '');
    return `https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${name}/${name}-original.svg`;
};

const getTechColor = (tech: string) => {
    const colors: Record<string, string> = {
        'react': '#2784F5',
        'kotlin': '#7F52FF',
        'supabase': '#3ECF8E',
        'flutter': '#02569B'
    };
    return colors[tech.toLowerCase().replace(/\s+/g, '')] || '#cccccc';
};
---

<div class="trabajos-wrapper-outer">
    <h2 class="glitch-text">{
        titleParts.map((part, index) => (
            <>{part}{index < titleParts.length - 1 && <span>_</span>}<wbr /></>
        ))
    }</h2>
    
    <div class="trabajos-container">
        {trabajos.map((trabajo, index) => (
            <div class="flip-card" data-aos="fade-up">
                <div class="flip-card-inner" id={`card-inner-${index}`}>
                    
                    <div class="flip-card-front">
                        <div class="image-header">
                            <img src={trabajo.image} alt={trabajo.title} class="imagen-trabajo" />
                        </div>
                        <div class="card-body">
                            <h3>{trabajo.title}</h3>
                            <p class="descripcion">{trabajo.description}</p>
                            <div class="tecnologias">
                                {trabajo.technologies.map(tech => (
                                    <span class="tech-badge" style={`border: 1px solid ${getTechColor(tech)}; background: ${getTechColor(tech)}22`}>
                                        <img src={getTechIcon(tech)} alt={tech} class="tech-icon" />
                                        <span class="tech-name" style={`color: ${getTechColor(tech)}`}>{tech}</span>
                                    </span>
                                ))}
                            </div>
                            <button class="flip-btn" onclick={`document.getElementById('card-inner-${index}').classList.add('is-flipped')`}>
                                {t('projects.btn.details')}
                            </button>
                        </div>
                    </div>

                    <div class="flip-card-back">
                        <div class="details-content">
                            <h4 class="details-title">{t('projects.label.specs')}</h4>
                            <div class="scroll-area">
                                <p class="details-text">{trabajo.details}</p>
                            </div>
                            <div class="action-links">
                                <a href={trabajo.github} target="_blank" class="github-link">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="github-icon"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
                                    {t('projects.label.code')}
                                </a>
                            </div>
                            <button class="back-btn" onclick={`document.getElementById('card-inner-${index}').classList.remove('is-flipped')`}>
                                {t('projects.btn.back')}
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        ))}
    </div>
</div>

<style>
    .trabajos-wrapper-outer {
        max-width: 1200px;
        margin: 80px auto;
        padding: 0 20px;
        font-family: 'Courier New', monospace;
    }

    .glitch-text {
        font-size: 2.5rem;
        font-weight: bold;
        letter-spacing: 4px; 
        color: var(--primary-color);
        text-shadow: 0 0 10px var(--primary-color);
        text-align: center;
        margin-bottom: 40px;
        line-height: 1.1;
        display: block;
        word-wrap: break-word; 
        overflow-wrap: break-word;
    }

    .glitch-text span {
        color: var(--primary-color);
        display: inline-block;
    }

    .trabajos-container {
        display: grid;
        grid-template-columns: repeat(3, 1fr); 
        gap: 2.5rem;
        perspective: 2000px; 
    }

    .flip-card {
        height: 520px;
        width: 100%;
    }

    .flip-card-inner {
        position: relative;
        width: 100%;
        height: 100%;
        transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
        transform-style: preserve-3d;
    }

    .is-flipped { transform: rotateY(180deg); }

    .flip-card-front, .flip-card-back {
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
        border-radius: 4px;
        border: 1px solid rgba(0, 255, 0, 0.2);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .flip-card-front { background-color: var(--bg-dark-light, #0c0c1a); }
    .image-header { height: 200px; overflow: hidden; border-bottom: 1px solid rgba(0, 255, 0, 0.1); }
    .imagen-trabajo { width: 100%; height: 100%; object-fit: cover; }

    .card-body { padding: 1.5rem; display: flex; flex-direction: column; flex-grow: 1; }
    .card-body h3 { color: #fff; font-size: 1.4rem; margin: 0 0 0.5rem 0; }
    .descripcion { color: var(--text-secondary, #a0a0a0); font-size: 0.9rem; margin-bottom: 1.5rem; }

    .tecnologias { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
    .tech-badge { padding: 4px 10px; border-radius: 2px; display: flex; align-items: center; gap: 6px; font-size: 0.75rem; }
    .tech-icon { width: 14px; height: 14px; }

    .flip-card-back {
        background-color: #080808;
        transform: rotateY(180deg);
        padding: 1.5rem;
        border-color: var(--primary-color);
    }

    .details-content { height: 100%; display: flex; flex-direction: column; }
    .details-title { color: var(--primary-color); font-size: 1rem; margin-bottom: 1rem; border-bottom: 1px solid rgba(0, 255, 0, 0.2); padding-bottom: 5px; }
    .scroll-area { flex-grow: 1; overflow-y: auto; }
    .details-text { font-size: 0.85rem; line-height: 1.6; color: #ddd; }

    /* ESTILO ACTUALIZADO PARA UN SOLO ENLACE */
    .action-links { 
        display: flex; 
        justify-content: center; 
        margin: 1.5rem 0; 
    }

    .github-link { 
        color: var(--primary-color); 
        text-decoration: none; 
        font-size: 0.9rem; 
        font-weight: bold;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border: 1px solid rgba(0, 255, 0, 0.2);
        border-radius: 4px;
        transition: 0.3s;
    }

    .github-link:hover {
        background: rgba(0, 255, 0, 0.1);
        border-color: var(--primary-color);
    }

    .flip-btn, .back-btn { width: 100%; padding: 12px; cursor: pointer; font-family: inherit; font-weight: bold; transition: 0.3s; background: transparent; }
    .flip-btn { border: 1px solid var(--primary-color); color: var(--primary-color); margin-top: auto; }
    .flip-btn:hover { background: var(--primary-color); color: #000; }
    .back-btn { border: 1px solid #ff4444; color: #ff4444; }
    .back-btn:hover { background: #ff4444; color: #fff; }

    @media (max-width: 1024px) {
        .trabajos-container { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
        .glitch-text { 
            font-size: 2.2rem; 
            letter-spacing: 2px; 
        }
        .trabajos-container { grid-template-columns: 1fr; }
        .flip-card { height: 480px; }
    }
</style>