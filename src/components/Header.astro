---
// Recibimos el idioma actual como prop desde la página
const { currentLang } = Astro.props;
---

<header>
    <div class="header-container">
        <div class="logo">
            <a href={`/${currentLang}/`} aria-label="Volver al inicio">
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                    <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="2"/>
                    <text x="20" y="26" text-anchor="middle" font-size="16" font-weight="bold" fill="currentColor">PC</text>
                </svg>
            </a>
        </div>

        <div class="controls-wrapper">
            <a href={currentLang === 'es' ? '/en/' : '/es/'} class="lang-toggle" title="Switch Language">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
                <span>{currentLang === 'es' ? 'EN' : 'ES'}</span>
            </a>

            <span class="divider">|</span>

            <button id="darkModeToggle" class="theme-toggle" aria-label="Toggle dark mode">
                <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"></circle>
                    <line x1="12" y1="1" x2="12" y2="3"></line>
                    <line x1="12" y1="21" x2="12" y2="23"></line>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                    <line x1="1" y1="12" x2="3" y2="12"></line>
                    <line x1="21" y1="12" x2="23" y2="12"></line>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                </svg>
                <svg class="moon-icon" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                </svg>
            </button>
        </div>
    </div>
</header>

<style>
    /* ----- HEADER ESTRUCTURA ----- */
    header {
        background-color: transparent;
        position: absolute; /* Flota sobre el contenido */
        top: 0;
        left: 0;
        width: 100%;
        padding: 1.5rem 0;
        z-index: 1000;
        pointer-events: none; /* No bloquea clics en el fondo */
    }

    .header-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        pointer-events: auto; /* Devolvemos el clic a los botones */
    }

    /* ----- LOGO ----- */
    .logo a {
        display: flex;
        align-items: center;
        color: var(--primary-color, #00ff00); 
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .logo a:hover {
        filter: drop-shadow(0 0 10px var(--primary-color));
        transform: scale(1.05);
    }

    /* ----- CONTROLES (CÁPSULA) ----- */
    .controls-wrapper {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        background-color: rgba(10, 10, 20, 0.5);
        backdrop-filter: blur(8px);
        padding: 6px 16px;
        border-radius: 30px;
        border: 1px solid var(--primary-color, #00ff00);
        box-shadow: 0 0 10px rgba(0, 255, 0, 0.1);
        transition: all 0.3s ease;
    }

    /* ----- IDIOMA ----- */
    .lang-toggle {
        display: flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        color: var(--primary-color, #00ff00);
        font-family: 'Courier New', monospace;
        font-weight: bold;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

    .lang-toggle:hover {
        filter: drop-shadow(0 0 8px var(--primary-color));
    }

    .divider {
        color: var(--primary-color, #00ff00);
        opacity: 0.4;
        font-weight: 300;
    }

    /* ----- TEMA ----- */
    .theme-toggle {
        background: transparent;
        border: none;
        cursor: pointer;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        padding: 0;
    }

    .theme-toggle svg {
        width: 20px;
        height: 20px;
        color: var(--primary-color, #00ff00);
        position: absolute;
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ----- ANIMACIONES SOL/LUNA ----- */
    .sun-icon { opacity: 1; transform: scale(1) rotate(0deg); }
    .moon-icon { opacity: 0; transform: scale(0) rotate(-180deg); }

    html.light-mode .sun-icon { opacity: 0; transform: scale(0) rotate(180deg); }
    html.light-mode .moon-icon { opacity: 1; transform: scale(1) rotate(0deg); }

    /* ----- MODO CLARO AJUSTES ----- */
    html.light-mode .controls-wrapper {
        background-color: rgba(255, 255, 255, 0.6);
        border-color: #333;
    }
    html.light-mode .lang-toggle, 
    html.light-mode .divider,
    html.light-mode .theme-toggle svg {
        color: #333;
    }

    /* ----- RESPONSIVE ----- */
    @media (max-width: 768px) {
        header { padding: 1rem 0; }
        .header-container { padding: 0 1rem; }
        .controls-wrapper { padding: 4px 12px; }
    }
</style>

<script>
    const initTheme = () => {
        const toggleButton = document.getElementById('darkModeToggle');
        const htmlElement = document.documentElement;

        const savedMode = localStorage.getItem('theme-mode');
        if (savedMode === 'light') {
            htmlElement.classList.add('light-mode');
        }

        if (toggleButton) {
            toggleButton.addEventListener('click', () => {
                htmlElement.classList.toggle('light-mode');
                const isLightMode = htmlElement.classList.contains('light-mode');
                localStorage.setItem('theme-mode', isLightMode ? 'light' : 'dark');
            });
        }
    }

    // Reinicializar después de cambios de página en Astro
    initTheme();
    document.addEventListener('astro:after-swap', initTheme);
</script>