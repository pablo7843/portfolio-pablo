---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();
const myEmail = "pclimentsanfelix@gmail.com";
---

<footer class="system-footer">
  <div class="footer-top-divider"></div>
  
  <div class="footer-content">
    <div class="footer-section diagnostic">
      <div class="status-group">
        <span class="pulse-dot green"></span>
        <span class="status-label">{t('footer.status.label')}: <span class="highlight">{t('footer.status.value')}</span></span>
      </div>
      <div class="status-group">
        <span class="pulse-dot blue"></span>
        <span class="status-label">{t('footer.encryption.label')}: <span class="highlight">AES-256</span></span>
      </div>
    </div>

    <div class="footer-section identity">
      <p class="brand">PABLO_CLIMENT <span class="version">v2.0.26</span></p>
      <p class="copy">© {currentYear} {t('footer.copy')}</p>
    </div>

    <div class="footer-section links">
      <div class="social-grid">
        <a href="https://github.com/pablo7843" target="_blank" class="social-link">
          <span class="cmd">></span> GITHUB
        </a>
        <a href="https://www.linkedin.com/in/pabloclimentsanfelix" target="_blank" class="social-link">
          <span class="cmd">></span> LINKEDIN
        </a>
        
        <button 
          id="copy-email" 
          class="social-link copy-trigger" 
          data-email={myEmail}
          data-original-text={t('footer.social.email')}
          data-copied-text={t('footer.social.copied')}
        >
          <span class="cmd">></span> 
          <span class="link-text">{t('footer.social.email')}</span>
        </button>
      </div>
    </div>
  </div>

  <div class="footer-bottom-bar">
    <div class="terminal-loader">
      <span class="loading-text">{t('footer.loading')}</span>
      <div class="mini-progress">
        <div class="mini-bar"></div>
      </div>
    </div>
  </div>
</footer>

<script>
  const copyBtn = document.getElementById('copy-email');
  const linkText = copyBtn?.querySelector('.link-text');

  copyBtn?.addEventListener('click', () => {
    const email = copyBtn.getAttribute('data-email') || '';
    const copiedText = copyBtn.getAttribute('data-copied-text') || '';
    const originalText = copyBtn.getAttribute('data-original-text') || '';

    // Lógica para copiar al portapapeles
    navigator.clipboard.writeText(email).then(() => {
      if (linkText) {
        // Feedback Visual: Cambio de texto y clase
        linkText.textContent = copiedText;
        copyBtn.classList.add('copied-success');

        // Restaurar estado original después de 2 segundos
        setTimeout(() => {
          linkText.textContent = originalText;
          copyBtn.classList.remove('copied-success');
        }, 2000);
      }
    });
  });
</script>

<style>
  .system-footer {
    margin-top: 100px;
    background-color: var(--bg-dark);
    color: var(--text-secondary);
    font-family: 'Courier New', monospace;
    position: relative;
    border-top: 1px solid rgba(0, 255, 0, 0.1);
    padding-bottom: 20px;
  }

  .footer-top-divider {
    height: 1px;
    width: 100%;
    background: linear-gradient(90deg, transparent, var(--primary-color), transparent);
    margin-bottom: 40px;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    padding: 0 20px;
    align-items: center;
  }

  /* Status Dots */
  .status-group {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
    font-size: 0.8rem;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .pulse-dot.green { background: #00ff00; box-shadow: 0 0 8px #00ff00; animation: blink 2s infinite; }
  .pulse-dot.blue { background: #0066cc; box-shadow: 0 0 8px #0066cc; animation: blink 1.5s infinite; }

  @keyframes blink { 50% { opacity: 0.3; } }

  .highlight { color: var(--primary-color); font-weight: bold; }

  /* Identidad */
  .identity { text-align: center; }
  .brand {
    font-size: 1.2rem;
    font-weight: bold;
    color: var(--text-primary);
    margin: 0;
    letter-spacing: 2px;
  }
  .version { font-size: 0.7rem; color: var(--primary-color); opacity: 0.6; }
  .copy { font-size: 0.7rem; opacity: 0.5; margin-top: 5px; }

  /* Links y Botón de Copiar */
  .social-grid {
    display: flex;
    flex-direction: column;
    gap: 5px;
    align-items: flex-end;
  }

  .social-link {
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .social-link:hover { color: var(--primary-color); transform: translateX(-5px); }
  .cmd { color: var(--primary-color); font-weight: bold; }

  /* Reset de estilos para el botón de copiar */
  .copy-trigger {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
    text-align: right;
  }

  /* Estilo cuando el email se copia con éxito */
  .copied-success .link-text {
    color: var(--primary-color);
    text-shadow: 0 0 10px var(--primary-color);
    font-weight: bold;
  }

  .copied-success .cmd {
    animation: blink 0.5s infinite;
  }

  /* Barra inferior */
  .footer-bottom-bar {
    margin-top: 40px;
    padding: 0 20px;
    display: flex;
    justify-content: center;
  }

  .terminal-loader {
    display: flex;
    align-items: center;
    gap: 15px;
    opacity: 0.4;
  }

  .loading-text { font-size: 0.65rem; }

  .mini-progress {
    width: 100px;
    height: 4px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    overflow: hidden;
  }

  .mini-bar {
    width: 40%;
    height: 100%;
    background: var(--primary-color);
    animation: slide 3s infinite linear;
  }

  @keyframes slide {
    from { transform: translateX(-100%); }
    to { transform: translateX(250%); }
  }

  /* MODO CLARO */
  :global(html.light-mode) .system-footer {
    background: #f0f0f0;
    border-top: 1px solid #ddd;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .footer-content { grid-template-columns: 1fr; text-align: center; }
    .social-grid { align-items: center; }
    .copy-trigger { text-align: center; }
  }
</style>