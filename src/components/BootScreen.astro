---
// Boot / BIOS POST screen — shows once per session before the dossier.
// Gated pre-paint by Layout (html.booting). Skippable, respects reduced-motion.
---

<div id="boot-screen" aria-hidden="true">
  <div class="boot-inner">
    <pre id="boot-log"></pre>
    <div id="boot-bar" class="boot-bar">
      <span class="boot-bar-fill"></span>
    </div>
    <p class="boot-skip">[ PRESS ANY KEY TO SKIP ]</p>
  </div>
  <div class="boot-scanlines" aria-hidden="true"></div>
</div>

<style>
  /* Visible only while booting; killed once boot-done */
  :global(html.boot-done) #boot-screen { display: none !important; }
  :global(html.booting), :global(html.booting body) { overflow: hidden; }

  #boot-screen {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    z-index: 100000;
    display: flex;
    background: #04060a;
    color: var(--primary-color, #00ff00);
    font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
    text-shadow: 0 0 6px color-mix(in srgb, var(--primary-color, #00ff00) 60%, transparent);
    opacity: 1;
    transition: opacity 0.35s ease;
  }
  #boot-screen.boot-fade { opacity: 0; }

  .boot-inner {
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    padding: clamp(20px, 5vh, 60px) clamp(20px, 5vw, 70px);
    display: flex;
    flex-direction: column;
  }

  #boot-log {
    margin: 0;
    flex: 1;
    font-size: clamp(0.95rem, 2.6vw, 1.35rem);
    line-height: 1.8;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .boot-ok  { color: #27c93f; }
  .boot-dim { opacity: 0.6; }

  .boot-bar {
    margin-top: 14px;
    height: 10px;
    border: 1px solid color-mix(in srgb, var(--primary-color, #00ff00) 50%, transparent);
    background: color-mix(in srgb, var(--primary-color, #00ff00) 8%, transparent);
    overflow: hidden;
  }
  .boot-bar-fill {
    display: block;
    height: 100%;
    width: 0;
    background: var(--primary-color, #00ff00);
    box-shadow: 0 0 10px var(--primary-color, #00ff00);
    transition: width 0.12s linear;
  }

  .boot-skip {
    margin: 16px 0 0;
    font-size: 0.7rem;
    letter-spacing: 2px;
    opacity: 0;
    animation: boot-blink 1s step-end infinite;
    animation-delay: 0.4s;
    animation-fill-mode: forwards;
  }
  @keyframes boot-blink { 0%, 50% { opacity: 0.85; } 51%, 100% { opacity: 0.15; } }

  /* CRT scanlines */
  .boot-scanlines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      rgba(0, 0, 0, 0.35) 3px,
      transparent 4px
    );
    mix-blend-mode: multiply;
    opacity: 0.5;
  }
</style>

<script is:inline>
(function () {
  var html = document.documentElement;
  if (!html.classList.contains('booting')) return; // skipped (already booted / reduced-motion)

  var screen = document.getElementById('boot-screen');
  var log    = document.getElementById('boot-log');
  var fill   = screen && screen.querySelector('.boot-bar-fill');
  if (!screen || !log || !fill) { done(true); return; }

  // BIOS POST sequence. {ok:true} appends a green "OK". delay = ms before line.
  var LINES = [
    { t: 'PCdev BIOS v2.6.14  —  Pablo Climent Sanfélix' },
    { t: 'Copyright (C) 2026  PC Systems. All rights reserved.' },
    { t: '' },
    { t: 'CPU      : Neural Core @ 4.8GHz', ok: true },
    { t: 'Memory   : 65536K RAM', ok: true },
    { t: 'Detecting storage devices ...', ok: true },
    { t: 'Loading kernel modules ...', ok: true },
    { t: 'Mounting /dev/portfolio ...', ok: true },
    { t: 'Starting display server ...', ok: true },
    { t: '' },
    { t: 'Boot sequence complete. Launching dossier ...', dim: true },
  ];

  var TOTAL_MS = 6500;        // target boot length (~6.5s, skippable)
  var step     = TOTAL_MS / LINES.length;
  var i        = 0;
  var finished = false;

  function render() {
    var out = '';
    for (var k = 0; k < i; k++) {
      var ln = LINES[k];
      var cls = ln.dim ? ' class="boot-dim"' : '';
      out += '<span' + cls + '>' + esc(ln.t) + (ln.ok ? '  <span class="boot-ok">[ OK ]</span>' : '') + '</span>\n';
    }
    log.innerHTML = out;
    fill.style.width = Math.min(100, (i / LINES.length) * 100) + '%';
  }

  function esc(s) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function tick() {
    if (finished) return;
    i++;
    render();
    if (i >= LINES.length) {
      fill.style.width = '100%';
      setTimeout(function () { done(false); }, 220);
      return;
    }
    setTimeout(tick, step);
  }

  function done(instant) {
    if (finished) return;
    finished = true;
    try { sessionStorage.setItem('pf-booted', '1'); } catch (e) {}
    window.removeEventListener('keydown', skip, true);
    screen.removeEventListener('click', skip, true);
    screen.removeEventListener('touchstart', skip, true);
    if (instant) {
      html.classList.remove('booting');
      html.classList.add('boot-done');
      return;
    }
    screen.classList.add('boot-fade');
    setTimeout(function () {
      html.classList.remove('booting');
      html.classList.add('boot-done');
    }, 360);
  }

  function skip() { done(false); }

  window.addEventListener('keydown', skip, true);
  screen.addEventListener('click', skip, true);
  screen.addEventListener('touchstart', skip, true);

  render();
  setTimeout(tick, step);
})();
</script>
